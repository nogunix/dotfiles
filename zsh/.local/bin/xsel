#!/usr/bin/env bash
set -euo pipefail

mode="input"
files=()
self_path="${BASH_SOURCE[0]}"
self_dir="$(cd -- "${self_path%/*}" && pwd)"

backend="$("$self_dir/clipboard-backend")"
backend_name="${backend%%:*}"
backend_cmd="${backend#*:}"

while (($# > 0)); do
  case "$1" in
    --clipboard|--primary|--secondary|-b|-p)
      ;;
    --input|-i)
      mode="input"
      ;;
    --output|-o)
      mode="output"
      ;;
    --)
      shift
      files+=("$@")
      break
      ;;
    -*)
      ;;
    *)
      files+=("$1")
      ;;
  esac
  shift || true
done

if [[ "$mode" == "output" ]]; then
  printf 'xsel wrapper: reading the local terminal clipboard over SSH is not supported\n' >&2
  exit 1
fi

case "$backend_name" in
  xsel)
    if ((${#files[@]} > 0)); then
      exec "$backend_cmd" --clipboard --input "${files[@]}"
    else
      exec "$backend_cmd" --clipboard --input
    fi
    ;;
  xclip)
    if ((${#files[@]} > 0)); then
      cat "${files[@]}" | "$backend_cmd" -selection clipboard
    else
      "$backend_cmd" -selection clipboard
    fi
    ;;
  wl-copy|osc52)
    if ((${#files[@]} > 0)); then
      cat "${files[@]}" | "$self_dir/clipboard-copy"
    else
      "$self_dir/clipboard-copy"
    fi
    ;;
  *)
    printf 'xsel wrapper: unsupported backend %s\n' "$backend_name" >&2
    exit 1
    ;;
esac
